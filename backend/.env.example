# Intent Firewall Backend — Environment Variables
# Copy to .env and fill in your values

# ── Required ─────────────────────────────────────────────────────────────────
# ArmorIQ SDK API Key (used as HMAC-SHA256 signing secret)
ARMORIQ_API_KEY=your_armoriq_api_key_here

# Supabase
SUPABASE_URL=https://udujxxgthjmjnioidxik.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVkdWp4eGd0aGptam5pb2lkeGlrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0OTExMjQsImV4cCI6MjA5ODA2NzEyNH0.vt6f1bVZG71Arl04TIlBprvEF--PjBb_o9mdzR_uGAk

# Drift Scoring — OpenAI (primary, per user preference)
OPENAI_API_KEY=your_openai_api_key_here

# Drift Scoring — Gemini (fallback when OpenAI unavailable)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ─────────────────────────────────────────────────────────────────
# Risk score threshold — actions at or above this need human review
RISK_THRESHOLD=7

# Drift threshold — below this % alignment triggers pending_review
DRIFT_REVIEW_THRESHOLD=70

# Drift block threshold — below this % alignment triggers blocked
DRIFT_BLOCK_THRESHOLD=30
